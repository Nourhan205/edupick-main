# ============================================================
# EduPick Backend — Environment Variables
# Copy this file to .env and fill in your keys. NEVER commit .env.
# ============================================================

# --- Database (MongoDB Atlas free M0 connection string) ---
# e.g. mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017/
MONGO_DB=graduation_project

# --- CORS: deployed frontend origin(s), comma-separated (use * for local dev) ---
# e.g. https://edupick.vercel.app
FRONTEND_ORIGIN=*

# --- LLM Providers ---
# Groq Cloud (https://console.groq.com)
GROQ_API_KEY=gsk_...
# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AI...
# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# --- Tool APIs ---
# Serper (https://serper.dev) — used by comparison_tool.py
SERPER_API_KEY=...

# --- Email (password reset) — Gmail App Password, NOT your login password ---
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=xxxxxxxxxxxxxxxx

# --- Model registry (optional — defaults to llama-3.3-70b-versatile) ---
# Change a model in ONE place; the plain-Groq pipelines read these.
# GROQ_MODEL=llama-3.3-70b-versatile
# ROADMAP_MODEL=llama-3.3-70b-versatile        # roadmap_agent.py
# CV_ANALYZER_MODEL=llama-3.3-70b-versatile    # cv_analyzer.py

# --- Optional overrides ---
# DATA_DIR=/app/data
# CHROMA_DIR=/data/chroma_interview
# PORT=5000
# FLASK_DEBUG=0
